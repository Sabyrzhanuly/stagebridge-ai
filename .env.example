# ── Пароли внутренней инфраструктуры ────────────────────────────────
# ЕДИНСТВЕННЫЙ источник правды: из них backend собирает полные URL
# (app/config.py), и их же подставляет docker-compose через ${...}.
# Ротация — одной командой: bash scripts/rotate_secret.sh <appdb|redis|rabbitmq>
# Сгенерировать каждый:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
APPDB_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
RABBITMQ_PASSWORD=CHANGE_ME

# ── Необязательный override полного URL ─────────────────────────────
# Нужен только для ВНЕШНИХ/managed-сервисов (не compose). Если задан —
# перекрывает сборку из паролей выше. По умолчанию оставить закомментированным.
#APP_DB_URL=postgresql+asyncpg://user:pass@host:5432/dbname
#APP_DB_URL_SYNC=postgresql://user:pass@host:5432/dbname
#REDIS_URL=redis://:pass@host:6379/0
#RABBITMQ_URL=amqp://user:pass@host:5672//

# S3/MinIO настраивается per-server в UI: Настройки → Хранилище S3

# ── Секреты приложения ──────────────────────────────────────────────
# Шифрование паролей серверов (Fernet). Ротация: scripts/rotate_secret.sh fernet
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here
# Подпись JWT — ОТДЕЛЬНЫЙ секрет, не переиспользовать FERNET_KEY.
# Ротация: scripts/rotate_secret.sh jwt  (инвалидирует выданные токены)
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your-jwt-secret-here

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=pgadmin@example.com
ALLOW_REGISTRATION=false

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@localhost
# Смените до первого запуска — учётка супер-админа платформы.
SUPER_ADMIN_PASSWORD=CHANGE_ME
